# --- Database (Neon Postgres) ---
NEON_DB_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require
DB_HOST=ep-xxxx.aws.neon.tech
DB_NAME=neondb
DB_USER=neondb_owner
DB_PASSWORD=changeme
DB_PORT=5432

# --- ETL engine defaults (used by both the UI "Run Pipeline" button and cron) ---
SOURCE_TABLE=source_data
DEST_TABLE=processed_data
BATCH_SIZE=30
NUM_TRANSFORMERS=4

# --- Backend ---
PORT=3001

# --- Optional: run the pipeline automatically on a schedule (standard cron syntax) ---
# Every 6 hours:
RUN_PIPELINE_CRON=0 */6 * * *
